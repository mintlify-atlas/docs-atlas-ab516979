  "keyFeatures": [
    "Real-time kanban boards with drag-and-drop",
    "Swimlanes for organizing cards into horizontal sections",
    "Custom fields for extending card data",
    "WIP (Work In Progress) limits per list",
    "Checklists, labels, attachments, and comments on cards",
    "Gantt chart and burndown/velocity chart views",
    "REST API for programmatic access",
    "Outgoing webhooks for integrations",
    "Import from Trello, Jira, Asana, and other Wekan instances",
    "Export to JSON, CSV, and Excel",
    "LDAP, OAuth2, and SAML authentication",
    "Multi-language support (105+ languages via Transifex)",
    "Self-hosted: Docker, Snap, Sandstorm, and bare-metal installs",
    "Admin panel for user management, settings, and email configuration",
    "Role-based permissions (admin, normal, comment-only, no-comments)"
  ],
  "publicApiSurface": [
    "POST /users/login",
    "POST /users/register",
    "GET /api/users",
    "GET /api/users/:id",
    "POST /api/users",
